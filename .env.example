# ============================================
# Donna - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ============================================

# Environment
ENVIRONMENT=dev                 # dev | prod
TIMEZONE=Europe/Paris

# Telegram
TELEGRAM_BOT_TOKEN=             # From @BotFather
ALLOWED_CHAT_IDS=               # Comma-separated chat IDs (e.g., 123456789,987654321)

# Anthropic
ANTHROPIC_API_KEY=              # From console.anthropic.com (sk-ant-...)

# Google Calendar
GOOGLE_CALENDAR_ID=             # Calendar ID (e.g., your@gmail.com)
GOOGLE_SERVICE_ACCOUNT_JSON=    # Entire JSON content of the service account key file (single line)

# Supabase
SUPABASE_URL=                   # Project URL (https://xxxxx.supabase.co)
SUPABASE_SERVICE_ROLE_KEY=      # service_role key (NOT the anon key)

# API FastAPI
API_URL=http://localhost:8000   # In prod: Railway URL of the API service
API_KEY=                        # Shared secret between bot and API (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")

# Scheduler
RECAP_MORNING_HOUR=7
RECAP_AFTERNOON_HOUR=13

# Pending actions
PENDING_EXPIRATION_MINUTES=30
